# Required outside local development
ADMIN_PASSWORD=choose-a-long-unique-password
SESSION_SECRET=generate-at-least-32-random-characters

# Required to enable passkeys in production
PASSKEY_RP_ID=cms.example.com
PASSKEY_ORIGIN=https://cms.example.com

# Optional
# Set only while new users should be allowed to enroll
SIGNUP_CODE=choose-a-long-private-enrollment-code
ADMIN_USERNAME=admin
PASSKEY_RP_NAME=Gutafinn CMS
PORT=3000
HOST=127.0.0.1
DATABASE_PATH=./data/places.db
NODE_ENV=production
