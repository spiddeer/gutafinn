[Unit]
Description=Gutafinn Docker Compose Stack
Requires=docker.service
After=docker.service network-online.target
Wants=network-online.target

[Service]
Type=oneshot
RemainAfterExit=yes
WorkingDirectory=/opt/gutafinn
ExecStart=/usr/bin/docker-compose -f deploy/proxmox/docker-compose.yml up -d --build
ExecStop=/usr/bin/docker-compose -f deploy/proxmox/docker-compose.yml down
TimeoutStartSec=0

[Install]
WantedBy=multi-user.target
